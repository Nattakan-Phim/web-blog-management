{
  "name": "backend",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "dev": "docker compose up -d && bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "db:migration:run": "bun run node_modules/typeorm/cli.js migration:run -d src/data-source.ts",
    "db:migration:revert": "bun run node_modules/typeorm/cli.js migration:revert -d src/data-source.ts",
    "db:migration:generate": "bun run node_modules/typeorm/cli.js migration:generate -d src/data-source.ts",
    "db:migration:create": "bun run node_modules/typeorm/cli.js migration:create",
    "db:seed-admin": "bun run src/scripts/seed-admin.ts",
    "db:download-mockup-images": "bun run src/scripts/download-mockup-images.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "@types/pg": "^8.20.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1035.0",
    "@aws-sdk/s3-request-presigner": "^3.1035.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/static": "^1.4.9",
    "@elysiajs/swagger": "^1.3.1",
    "bcryptjs": "^3.0.3",
    "elysia": "^1.4.28",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28"
  }
}